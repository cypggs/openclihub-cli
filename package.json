{
  "name": "openclihub",
  "version": "0.1.1",
  "description": "Search, browse and install CLI tools from OpenCLI Hub",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openclihub": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "tools",
    "directory",
    "ai-agent",
    "openclihub"
  ],
  "author": "cypggs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cypggs/openclihub-cli"
  },
  "homepage": "https://openclihub.com",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^6.0.2"
  }
}
